  updatedAt    DateTime    @updatedAt
  category     FinCategory @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, contractId, departmentId, year, month, categoryId])
  @@map("fin_monthly_summaries")
}

/// еҸ°иҙҰеҜје…Ҙи®°еҪ•
model FinImportLog {
  id          String   @id @default(cuid())
  tenantId    String
  fileName    String
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errorDetail String?
  importedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  @@map("fin_import_logs")
}

/// еҸ‘зҘЁи®°еҪ•пјҲиҙўеҠЎжЁЎеқ—пјҢдёҺи®ўйҳ…еҸ‘зҘЁ Invoice дёҚеҗҢпјү
model FinInvoice {
  id          String       @id @default(cuid())
  tenantId    String
  contractId  String?
  invoiceNo   String       // еҸ‘зҘЁеҸ·з Ғ
  invoiceType String       @default("vat_special") // vat_special/vat_normal/general/other
  invoiceDate String       // ејҖзҘЁж—Ҙжңҹ
  amount      Float        // еҸ‘зҘЁйҮ‘йўқпјҲеҗ«зЁҺпјү
  taxRate     Float        @default(0) // зЁҺзҺҮ
  taxAmount   Float        @default(0) // зЁҺйўқ
  buyerName   String?      // иҙӯд№°ж–№пјҲз”Іж–№пјү
  description String?      // еҸ‘зҘЁйЎ№зӣ®/еӨҮжіЁ
  imagePath   String?      // еҸ‘зҘЁеӣҫзүҮи·Ҝеҫ„
  status      String       @default("issued") // draft/issued/void
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  receipts    FinReceipt[] // е…іиҒ”зҡ„ж”¶ж¬ҫи®°еҪ•

  @@map("fin_invoices")
}

/// ж”¶ж¬ҫ/иҝӣж¬ҫи®°еҪ•
model FinReceipt {
  id            String     @id @default(cuid())
  tenantId      String
  contractId    String     // е…іиҒ”еҗҲеҗҢпјҲеҝ…еЎ«пјү
  invoiceId     String?    // е…іиҒ”еҸ‘зҘЁпјҲеҸҜйҖүпјү
  amount        Float      // жң¬ж¬Ўиҝӣж¬ҫйҮ‘йўқ
  receiptDate   String     // ж”¶ж¬ҫж—Ҙжңҹ
  paymentMethod String     @default("bank_transfer") // bank_transfer/cash/check/other
  payerName     String?    // д»ҳж¬ҫж–№
  bankAccount   String?    // ж”¶ж¬ҫиҙҰжҲ·
  transactionNo String?    // й“¶иЎҢжөҒж°ҙеҸ·
  enteredBy     String     // еҪ•е…Ҙдәә
  remark        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  invoice       FinInvoice? @relation(fields: [invoiceId], references: [id])

  @@map("fin_receipts")
}
