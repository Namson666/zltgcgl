generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

/// е№іеҸ°ејҖеҸ‘иҖ…/и¶…зә§з®ЎзҗҶе‘ҳ
/// еҗҲе№¶дәҶеҺҹWMSзҡ„Developerе’ҢеҺҹLaborзҡ„SuperAdmin
model Developer {
  id            String         @id @default(cuid())
  username      String         @unique
  passwordHash  String
  name          String
  email         String?
  phone         String?
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  aiConfigs         AiConfig[]
  ocrConfigs         OcrConfig[]
  operationLogs      OperationLog[]
  integrationConfigs IntegrationConfig[]

  @@map("developers")
}

/// AIжЁЎеһӢй…ҚзҪ®пјҲејҖеҸ‘иҖ…еҗҺеҸ°з»ҹдёҖз®ЎзҗҶпјү
model AiConfig {
  id          String    @id @default(cuid())
  developerId String
  provider    String
  model       String
  apiKey      String
  baseUrl     String?
  isEnabled   Boolean   @default(false)
  config      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@map("ai_configs")
}

/// OCRй…ҚзҪ®пјҲејҖеҸ‘иҖ…еҗҺеҸ°з»ҹдёҖз®ЎзҗҶпјү
/// еҗҲе№¶дәҶеҺҹWMSзҡ„OcrConfigе’ҢзҺҜеўғеҸҳйҮҸй…ҚзҪ®
model OcrConfig {
  id          String    @id @default(cuid())
  developerId String
  provider    String
  secretId    String?
  secretKey   String?
  apiKey      String?
  isEnabled   Boolean   @default(false)
  config      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  developer   Developer @relation(fields: [developerId], references: [id], onDelete: Cascade)

  @@map("ocr_configs")
}

/// ж–Ҫе·ҘдјҒдёҡпјҲз§ҹжҲ·пјү
/// еҗҲе№¶дәҶеҺҹWMSзҡ„Companyе’ҢеҺҹLaborзҡ„Tenant
model Tenant {
  id             String          @id @default(cuid())
  name           String
  code           String          @unique
  contactName    String?
  contactPhone   String?
  address        String?
  isActive       Boolean         @default(true)
  deletedAt      DateTime?       // иҪҜеҲ йҷӨж—¶й—ҙпјҢдёҚдёә null иЎЁзӨәе·ІеҲ йҷӨ
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  attachments      Attachment[]
  contracts        Contract[]
  departments      Department[]
  invoices         Invoice[]
  materials        Material[]
  operationLogs    OperationLog[]
  personnel        Personnel[]
  roles            Role[]
  subcontractors   Subcontractor[]
  subscription     Subscription?
  moduleEntitlements TenantModuleEntitlement[]
  suppliers        Supplier[]
  users            User[]
  workTeams        WorkTeam[]

  @@map("tenants")
}

/// дјҒдёҡжЁЎеқ—ејҖйҖҡи®°еҪ•
/// еҗҲеҗҢз®ЎзҗҶжҳҜй»ҳи®ӨеҹәзЎҖеҠҹиғҪпјҢдёҚиҝӣе…ҘиҜҘиЎЁпјӣиҝҷйҮҢеҸӘжҺ§еҲ¶ wms / labor / financeгҖӮ
model TenantModuleEntitlement {
  id         String    @id @default(cuid())
  tenantId   String
  moduleKey  String
  isEnabled  Boolean   @default(true)
  enabledAt  DateTime  @default(now())
  disabledAt DateTime?
  expiresAt  DateTime?
  remark     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleKey])
  @@index([tenantId])
  @@map("tenant_module_entitlements")
}

/// и®ўйҳ…дҝЎжҒҜ
model Subscription {
  id                 String                @id @default(cuid())
  tenantId           String                @unique
  plan               String                @default("FULL")
  tier               String                @default("SMALL")
  maxUsers           Int                   @default(5)
  pricePerMonth      Float                 @default(888)
  pricePerExtraUser  Float                 @default(100)
  currentUsers       Int                   @default(0)
  status             String                @default("TRIAL")
  trialEndAt         DateTime
  currentPeriodStart DateTime              @default(now())
  currentPeriodEnd   DateTime
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  payments           SubscriptionPayment[]
  tenant             Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

/// и®ўйҳ…ж”Ҝд»ҳи®°еҪ•
model SubscriptionPayment {
  id             String       @id @default(cuid())
  subscriptionId String
  amount         Float
  paymentMethod  String
  transactionId  String?
  status         String       @default("pending")
  paidAt         DateTime?
  createdAt      DateTime     @default(now())
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("subscription_payments")
}

/// еҗҲеҗҢпјҲз»ҹдёҖжЁЎеһӢпјү
/// еҺҹWMSзҡ„ContractпјҲдҫӣеә”е•ҶйҮҮиҙӯеҗҲеҗҢпјүе’ҢеҺҹLaborзҡ„ContractпјҲжүҝеҢ…еҗҲеҗҢпјүеҗҲе№¶
/// йҖҡиҝҮ contractType еҢәеҲҶ
model Contract {
  id               String            @id @default(cuid())
  tenantId         String
  type             String            @default("CONSTRUCTION")
  name             String
  code             String?
  totalAmount      Float?
  supplierId       String?
  awardingParty    String?
  description      String?
  startDate        DateTime?
  endDate          DateTime?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  supplier         Supplier?         @relation(fields: [supplierId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deliveryOrders   DeliveryOrder[]
  departments      Department[]
  inboundOrders    InboundOrder[]
  progressPayments ProgressPayment[]
  subContracts     SubContract[]

  @@unique([tenantId, code])
  @@map("contracts")
}

/// иҝӣеәҰж¬ҫж”¶ж¬ҫи®°еҪ•пјҲеҺҹLaborпјү
model ProgressPayment {
  id         String   @id @default(cuid())
  contractId String
  tenantId   String
  amount     Float
  receivedAt DateTime
  remark     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("progress_payments")
}

/// йЎ№зӣ®йғЁпјҲж•°жҚ®йҡ”зҰ»ж ёеҝғеҚ•е…ғпјү
/// ж–°еўһжЁЎеһӢпјҢж»Ўи¶і"еҗҲеҗҢвҶ’йЎ№зӣ®йғЁвҶ’еӯҗйЎ№зӣ®"дёүзә§з»“жһ„йңҖжұӮ
/// йЎ№зӣ®йғЁд№Ӣй—ҙж•°жҚ®дёҘж јйҡ”зҰ»
model Department {
  id                 String                    @id @default(cuid())
  tenantId           String
  contractId         String?
  name               String
  code               String
  description        String?
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  deliveryOrders     DeliveryOrder[]
  authorizedUsers    DepartmentAuthorization[]
  contract           Contract?                 @relation(fields: [contractId], references: [id])
  tenant             Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inboundOrders      InboundOrder[]
  inventories        Inventory[]
  outboundOrders     OutboundOrder[]
  personnel          Personnel[]
  returnOrders       ReturnOrder[]
  subProjects        SubProject[]               @relation("DepartmentSubProjects")
  transferOrdersTo   TransferOrder[]           @relation("TransferTo")
  transferOrdersFrom TransferOrder[]           @relation("TransferFrom")
  users              User[]

  @@unique([tenantId, code])
  @@map("departments")
}

/// еӯҗйЎ№зӣ®/йЎ№зӣ®еҗҚз§°
/// еҺҹWMSзҡ„ProjectйҷҚзә§дёәSubProjectпјҢеҪ’еұһDepartment
model SubProject {
  id                 String          @id @default(cuid())
  tenantId           String
  departmentId       String
  name               String
  code               String?
  description        String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  inboundOrders      InboundOrder[]
  inventories        Inventory[]
  outboundOrders     OutboundOrder[]
  returnOrders       ReturnOrder[]
  department         Department      @relation("DepartmentSubProjects", fields: [departmentId], references: [id], onDelete: Cascade)
  transferOrdersTo   TransferOrder[] @relation("TransferToSub")
  transferOrdersFrom TransferOrder[] @relation("TransferFromSub")

  @@unique([tenantId, departmentId, code])
  @@map("sub_projects")
}

/// зі»з»ҹз”ЁжҲ·пјҲз»ҹдёҖжЁЎеһӢпјү
/// еҗҲе№¶дәҶеҺҹWMSзҡ„Userе’ҢеҺҹLaborзҡ„TenantUser
model User {
  id                    String                    @id @default(cuid())
  tenantId              String
  departmentId          String?
  username              String
  passwordHash          String
  name                  String
  phone                 String?
  email                 String?
  roleId                String
  dataScope             String                    @default("OWN_DEPARTMENT")
  isActive              Boolean                   @default(true)
  lastLoginAt           DateTime?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  authorizedDepartments DepartmentAuthorization[]
  inboundOrders         InboundOrder[]            @relation("InboundCreator")
  operationLogs         OperationLog[]
  outboundOrders        OutboundOrder[]           @relation("OutboundCreator")
  returnOrders          ReturnOrder[]             @relation("ReturnCreator")
  role                  Role                      @relation(fields: [roleId], references: [id])
  department            Department?               @relation(fields: [departmentId], references: [id])
  tenant                Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, username])
  @@map("users")
}

/// и§’иүІпјҲеҠЁжҖҒи§’иүІжЁЎеһӢпјү
/// еҗҲе№¶дәҶеҺҹWMSзҡ„Roleе’ҢеҺҹLaborзҡ„жһҡдёҫTenantRole
model Role {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  displayName String
  description String?
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[]
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name])
  @@map("roles")
}

/// жқғйҷҗй…ҚзҪ®пјҲз»ҶзІ’еәҰжқғйҷҗжҺ§еҲ¶пјү
/// еҗҲе№¶дәҶеҺҹWMSзҡ„Permissionе№¶жү©еұ•
model Permission {
  id                    String   @id @default(cuid())
  roleId                String
  canViewDashboard      Boolean  @default(false)
  canManageSystem       Boolean  @default(false)
  canViewLogs           Boolean  @default(false)
  canExport             Boolean  @default(false)
  canViewInventory      Boolean  @default(false)
  canInbound            Boolean  @default(false)
  canOutbound           Boolean  @default(false)
  canReturn             Boolean  @default(false)
  canTransfer           Boolean  @default(false)
  canViewRecords        Boolean  @default(false)
  canViewWorkTeamLedger Boolean  @default(false)
  canManagePersonnel    Boolean  @default(false)
  canManageAttendance   Boolean  @default(false)
  canManageSalary       Boolean  @default(false)
  canManagePayment      Boolean  @default(false)
  canManageAnomaly      Boolean  @default(false)
  canManageReport       Boolean  @default(false)
  canManageContract     Boolean  @default(false)
  canManageDepartment   Boolean  @default(false)
  canFinanceView        Boolean  @default(false)
  canFinanceEntryDept   Boolean  @default(false)
  canFinanceEntryFinance Boolean @default(false)
  canFinanceApprove     Boolean  @default(false)
  canFinancePettyCash   Boolean  @default(false)
  canFinanceInvoice     Boolean  @default(false)
  canFinanceReceipt     Boolean  @default(false)
  canFinancePnl         Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  role                  Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("permissions")
}

/// з”ЁжҲ·-йЎ№зӣ®йғЁжҺҲжқғиЎЁ
/// з”ЁдәҺ LABORгҖҒMATERIAL зӯүи§’иүІзҡ„йЎ№зӣ®йғЁжҺҲжқғ
/// еҺҹ Labor зҡ„ ContractAuthorization жү©еұ•дёә Department з»ҙеәҰ
model DepartmentAuthorization {
  id           String     @id @default(cuid())
  userId       String
  departmentId String
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@map("department_authorizations")
}

/// дҫӣеә”е•ҶпјҲе…Ёз§ҹжҲ·е…ұдә«пјҢзү©иө„е’ҢеҠіиө„жЁЎеқ—йғҪеҸҜеј•з”Ёпјү
/// еҺҹWMSзҡ„Supplier
model Supplier {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  contactName    String?
  phone          String?
  address        String?
  bankAccount    String?
  bankName       String?
  remark         String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  contracts      Contract[]
  deliveryOrders DeliveryOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("suppliers")
}

/// зҸӯз»„пјҲе…Ёз§ҹжҲ·е…ұдә«пјҢзү©иө„еҮәеә“е’ҢеҠіиө„иҖғеӢӨйғҪеҸҜеј•з”Ёпјү
/// еҺҹWMSзҡ„WorkTeam
model WorkTeam {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  leaderName  String?
  phone       String?
  memberCount Int?
  remark      String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("work_teams")
}

/// еҲҶеҢ…е•ҶпјҲеҠіиө„жЁЎеқ—дё“з”Ёпјү
/// еҺҹLaborзҡ„Subcontractor
model Subcontractor {
  id           String        @id @default(cuid())
  tenantId     String
  type         String        @default("COMPANY")
  companyName  String
  contactName  String?
  contactPhone String?
  idCardNo     String?
  address      String?
  bankAccount  String?
  bankName     String?
  remark       String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  personnel    Personnel[]
  subContracts SubContract[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subcontractors")
}

/// зү©иө„зӣ®еҪ•
/// еҺҹWMSзҡ„Material
model Material {
  id                 String              @id @default(cuid())
  tenantId           String
  code               String?
  name               String
  spec               String?
  unit               String
  unitPrice          Float?
  category           String?
  alertThreshold     Int?
  remark             String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deliveryOrderItems DeliveryOrderItem[]
  inboundItems       InboundItem[]
  inventories        Inventory[]
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  outboundItems      OutboundItem[]
  returnBorrowItems  ReturnBorrowItem[]
  returnItems        ReturnItem[]
  transferItems      TransferItem[]

  @@map("materials")
}

/// еә“еӯҳ
/// еҺҹWMSзҡ„InventoryпјҢеўһеҠ departmentIdе’ҢsubProjectId
model Inventory {
  id           String      @id @default(cuid())
  tenantId     String
  departmentId String?
  subProjectId String?
  materialId   String
  quantity     Float       @default(0)
  projectName  String?
  outQuantity  Float       @default(0)
  isActive     Boolean     @default(true)
  updatedAt    DateTime    @updatedAt
  createdAt    DateTime    @default(now())
  material     Material    @relation(fields: [materialId], references: [id], onDelete: Cascade)
  subProject   SubProject? @relation(fields: [subProjectId], references: [id])
  department   Department? @relation(fields: [departmentId], references: [id])

  @@unique([subProjectId, materialId, projectName])
  @@index([subProjectId, materialId])
  @@map("inventories")
}

/// йҖҒиҙ§еҚ•
/// еҺҹWMSзҡ„DeliveryOrder
model DeliveryOrder {
  id            String              @id @default(cuid())
  tenantId      String
  orderNo       String
  supplierId    String?
  contractId    String?
  departmentId  String?
  subProjectId  String?
  deliveryDate  DateTime
  source        String              @default("MANUAL")
  ocrRawText    String?
  remark        String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  items         DeliveryOrderItem[]
  department    Department?         @relation(fields: [departmentId], references: [id])
  contract      Contract?           @relation(fields: [contractId], references: [id])
  supplier      Supplier?           @relation(fields: [supplierId], references: [id])
  inboundOrders InboundOrder[]

  @@map("delivery_orders")
}

/// йҖҒиҙ§еҚ•жҳҺз»Ҷ
/// еҺҹWMSзҡ„DeliveryOrderItem
model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String
  materialId      String?
  materialName    String
  spec            String?
  unit            String?
  deliveryQty     Float
  receivedQty     Float         @default(0)
  actualQty       Float
  unitPrice       Float?
  projectName     String?
  projectCode     String?
  material        Material?     @relation(fields: [materialId], references: [id])
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)

  @@map("delivery_order_items")
}

/// е…Ҙеә“еҚ•
/// еҺҹWMSзҡ„InboundOrder
model InboundOrder {
  id              String         @id @default(cuid())
  tenantId        String
  orderNo         String
  contractId      String?
  departmentId    String?
  subProjectId    String?
  deliveryOrderId String?
  inboundDate     DateTime
  source          String         @default("MANUAL")
  createdBy       String?
  supplierName    String?
  remark          String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           InboundItem[]
  creator         User?          @relation("InboundCreator", fields: [createdBy], references: [id])
  deliveryOrder   DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  subProject      SubProject?    @relation(fields: [subProjectId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])
  contract        Contract?      @relation(fields: [contractId], references: [id])

  @@map("inbound_orders")
}

/// е…Ҙеә“жҳҺз»Ҷ
/// еҺҹWMSзҡ„InboundItem
model InboundItem {
  id             String       @id @default(cuid())
  inboundOrderId String
  materialId     String
  quantity       Float
  unitPrice      Float?
  unit           String?
  projectName    String?
  material       Material     @relation(fields: [materialId], references: [id])
  inboundOrder   InboundOrder @relation(fields: [inboundOrderId], references: [id], onDelete: Cascade)

  @@map("inbound_items")
}

/// еҮәеә“еҚ•
/// еҺҹWMSзҡ„OutboundOrder
model OutboundOrder {
  id           String         @id @default(cuid())
  tenantId     String
  departmentId String?
  subProjectId String?
  workTeamId   String?
  workTeamName String?
  orderNo      String
  outboundDate DateTime
  createdBy    String?
  remark       String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        OutboundItem[]
  creator      User?          @relation("OutboundCreator", fields: [createdBy], references: [id])
  subProject   SubProject?    @relation(fields: [subProjectId], references: [id])
  department   Department?    @relation(fields: [departmentId], references: [id])
  returnOrders ReturnOrder[]

  @@map("outbound_orders")
}

/// еҮәеә“жҳҺз»Ҷ
/// еҺҹWMSзҡ„OutboundItem
model OutboundItem {
  id              String        @id @default(cuid())
  outboundOrderId String
  materialId      String
  subProjectId    String?
  subProjectName  String?
  projectName     String?       /// еҮәеә“ж—¶зү©иө„еҜ№еә”зҡ„е…Ҙеә“йЎ№зӣ®еҗҚз§°
  quantity        Float
  unitPrice       Float?
  unit            String?
  material        Material      @relation(fields: [materialId], references: [id])
  outboundOrder   OutboundOrder @relation(fields: [outboundOrderId], references: [id], onDelete: Cascade)
  returnItems     ReturnItem[]

  @@map("outbound_items")
}

/// йҖҖеә“еҚ•
/// еҺҹWMSзҡ„ReturnOrder
model ReturnOrder {
  id              String         @id @default(cuid())
  tenantId        String
  departmentId    String?
  subProjectId    String?
  workTeamId      String?
  workTeamName    String?
  outboundOrderId String?
  orderNo         String
  returnDate      DateTime
  source          String         @default("manual")
  createdBy       String?
  remark          String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  items           ReturnItem[]
  creator         User?          @relation("ReturnCreator", fields: [createdBy], references: [id])
  outboundOrder   OutboundOrder? @relation(fields: [outboundOrderId], references: [id])
  subProject      SubProject?    @relation(fields: [subProjectId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])

  @@map("return_orders")
}

/// йҖҖеә“жҳҺз»Ҷ
