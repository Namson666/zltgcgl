# ============================================
# 资料通工程管理系统 - 后端环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值

# 服务器配置
PORT=4001
NODE_ENV=development

# 数据库配置
DATABASE_URL=postgresql://zlt_user:Zlt_password_2024@localhost:5432/zlt_management

# JWT 配置
JWT_SECRET=zlt-jwt-secret-change-in-production-2024
JWT_EXPIRES_IN=7d
JWT_DEV_VIEW_EXPIRES_IN=4h

# 文件上传
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# 人脸识别服务
# stub：本地测试；http/tencent/baidu/aliyun：通过统一 HTTP 网关转接第三方云服务
FACE_RECOGNITION_HTTP_ENDPOINT=
FACE_RECOGNITION_HTTP_API_KEY=
FACE_RECOGNITION_THRESHOLD=0.8
FACE_RECOGNITION_TIMEOUT_MS=8000

# MiniMax AI 配置（默认值，可在开发者后台覆盖）
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=abab6.5s-chat

# 百度 OCR 配置（默认值，可在开发者后台覆盖）
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# 腾讯云 OCR 配置（默认值，可在开发者后台覆盖）
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=

# 短信服务配置（阿里云短信）
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=资料通
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# 微信支付配置
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=

# 支付宝配置
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# 钉钉配置
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_CORP_ID=

# 企业微信配置
WEWORK_CORP_ID=
WEWORK_AGENT_ID=
WEWORK_SECRET=

# 飞书配置
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Redis 配置（可选，用于缓存和限流）
REDIS_URL=redis://localhost:6379

# 前端地址（CORS 白名单）
FRONTEND_URL=http://localhost:5173
